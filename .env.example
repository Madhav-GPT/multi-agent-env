# Copy to `.env` for local use. `.env` is ignored by git.
# Keep provider separate from model ID; this repo passes provider explicitly.

# Required for real HF specialist calls and optional HF commander runs.
HF_TOKEN=
INFRA_SPECIALIST_MODEL=Qwen/Qwen3-4B-Thinking-2507
INFRA_SPECIALIST_PROVIDER=nscale
LOG_SPECIALIST_MODEL=Qwen/Qwen2.5-Coder-3B-Instruct
LOG_SPECIALIST_PROVIDER=nscale
SEC_SPECIALIST_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
SEC_SPECIALIST_PROVIDER=nscale

# Commander runtime options.
COMMANDER_PROVIDER=hf
COMMANDER_MODEL=Qwen/Qwen3-4B-Instruct-2507
MODEL_NAME=Qwen/Qwen3-4B-Instruct-2507
COMMANDER_HF_PROVIDER=nscale

# Optional local OpenAI-compatible commander endpoint.
API_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=local
